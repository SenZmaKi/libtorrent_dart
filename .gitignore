# libtorrent_dart
binaries/android/*
binaries/macos/*
binaries/ios/*
binaries/linux/*
binaries/windows/*
!binaries/android/.gitkeep
!binaries/macos/.gitkeep
!binaries/ios/.gitkeep
!binaries/linux/.gitkeep
!binaries/windows/.gitkeep

# Dart
.dart_tool/
.packages
pubspec.lock
build/

# CMake / C++ build artifacts
CMakeUserPresets.json
cmake_build/
cmake-build-*/
CMakeCache.txt
CMakeFiles/
Makefile
*.make
*.cmake
!CMakeLists.txt

# Cross-compiled third-party static libs (build output, not source)
thirdparty/openssl-android/
thirdparty/openssl-windows/

# Compiled binaries (prebuilts are explicitly allowed in binaries/)
*.o
*.a
*.lo
*.la
*.dylib
*.so
*.so.*
*.dll
*.exe
!binaries/**/*.dylib
!binaries/**/*.so
!binaries/**/*.dll
!binaries/**/*.exe
!binaries/**/*.a

# macOS
.DS_Store
*.dSYM/

# Editor
.vscode/
.idea/
*.swp
*.swo

# Logs
*.log
